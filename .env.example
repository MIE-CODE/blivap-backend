NODE_ENV="development"

PORT="2001"
APP_NAME="BLIVAP API"
APP_SLUG="blivap-api"

MONGODB_URI="mongodb://localhost:27017/blivap-api"


THROTTLE_TTL="60000"
THROTTLE_LIMIT="10"

CACHE_TTL="30000"

JWT_SECRET="your-secret-here"
JWT_EXPIRES_IN="24 hours"

REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_USE_TLS="false"

# Cloudinary (for avatar hosting)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_AVATAR_FOLDER="avatars"


# Public web / client app origin (no trailing slash). Used for password reset links and elsewhere.
# Prefer CLIENT_BASE_URL; FRONTEND_URL and PASSWORD_RESET_BASE_URL are fallbacks.
CLIENT_BASE_URL="https://yourapp.com"

